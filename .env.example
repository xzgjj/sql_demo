# MiniDB-Lab Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ===== Proxy Client Authentication =====
# Credentials for MySQL clients connecting to the proxy (port 3306)
MINIDB_PROXY_USER=proxy
MINIDB_PROXY_PASSWORD=proxy123

# ===== Proxy Backend MySQL Authentication =====
# Credentials used by the proxy to connect to backend MySQL instances
MINIDB_BACKEND_USER=root
MINIDB_BACKEND_PASSWORD=root123

# ===== MySQL Root Password (for Docker containers) =====
MINIDB_MYSQL_ROOT_PASSWORD=root123

# ===== Order API Authentication =====
# API Key for web-console to access order-api endpoints
# Leave empty for test/dev mode (allows all requests)
MINIDB_API_KEY=test-key-123

# ===== Order API Database (when running against a real MySQL) =====
MINIDB_DATASOURCE_USERNAME=root
MINIDB_DATASOURCE_PASSWORD=root123

# ===== Payment Signature =====
# Secret key used to verify mock payment callback signatures
MINIDB_PAYMENT_SIGN_SECRET=minidb-mock-pay-secret-key-2026

# ===== Proxy Network Configuration =====
MINIDB_PROXY_PORT=3306
MINIDB_PROXY_HOST=127.0.0.1
MINIDB_PROXY_MGMT_PORT=4307
MINIDB_BACKEND_HOST=127.0.0.1
MINIDB_BACKEND_PORT_BASE=4407
MINIDB_SHARD_COUNT=4

# ===== Shard Direct Connection (for 2PC Coordinator) =====
# Shard port base = 4409 (shard_0), 4410 (shard_1), etc.
MINIDB_SHARD_PORT_BASE=4409
MINIDB_SHARD_DATABASE_PREFIX=minidb_shard_
